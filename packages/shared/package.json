{
    "name": "@proton/shared",
    "description": "Proton shared",
    "license": "GPL-3.0",
    "author": "ProtonMail",
    "sideEffects": false,
    "scripts": {
        "check-types": "tsc",
        "i18n:validate": "proton-i18n validate lint-functions lib",
        "lint": "eslint --quiet",
        "pretty": "prettier --write $(find lib -type f -name '*.js' -o -name '*.ts' -o -name '*.tsx')",
        "test": "TZ=UTC vitest",
        "test:ci": "yarn test --run --silent=passed-only",
        "test:watch": "yarn test --watch",
        "generate-date-fns-locales-map": "node lib/i18n/generateDateFnsLocaleMap.ts lib/i18n/dateFnsLocaleMap.ts && prettier --write lib/i18n/dateFnsLocaleMap.ts"
    },
    "dependencies": {
        "@mattiasbuelens/web-streams-adapter": "0.1.0",
        "@proton/colors": "workspace:^",
        "@proton/sanitize": "workspace:^",
        "@proton/styles": "workspace:^",
        "@protontech/bip39": "^1.1.0",
        "@protontech/crypto": "*",
        "@protontech/mimemessage": "~v1.1.4",
        "@protontech/mutex-browser": "^1.0.5",
        "@protontech/telemetry": "^2.0.0",
        "@protontech/tidy-url": "^1.18.5",
        "@protontech/timezone-support": "^2.1.0",
        "@scure/base": "^2.2.0",
        "@sentry/browser": "^7.120.4",
        "@types/node": "^24.12.4",
        "@types/papaparse": "^5.5.2",
        "@types/ua-parser-js": "^0.7.39",
        "@types/webpack-env": "^1.18.8",
        "date-fns": "^2.30.0",
        "dompurify": "^3.4.2",
        "file-saver": "^2.0.5",
        "ical.js": "^1.5.0",
        "idb": "^8.0.3",
        "is-valid-domain": "0.1.6",
        "loglevel": "^1.9.2",
        "papaparse": "^5.5.3",
        "ua-parser-js": "^1.0.41",
        "web-streams-polyfill": "^3.3.3",
        "web-vitals": "^4.2.4",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@proton/eslint-config-proton": "workspace:^",
        "@proton/i18n": "workspace:^",
        "@proton/types": "workspace:^",
        "@types/file-saver": "^2.0.5",
        "@vitest/browser-playwright": "^4.1.6",
        "@webgpu/types": "^0.1.70",
        "eslint": "^9.39.4",
        "playwright": "patch:playwright@npm%3A1.58.2#~/.yarn/patches/playwright-npm-1.58.2-0c12daad27.patch",
        "prettier": "^3.8.3",
        "ttag": "^1.8.12",
        "typescript": "^6.0.2",
        "vitest": "^4.1.6"
    }
}
