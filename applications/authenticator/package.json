{
    "name": "proton-authenticator",
    "scripts": {
        "build:desktop": "cross-env NODE_ENV=production API_ENV=proton.me tools/build.sh",
        "build:web": "cross-env NODE_ENV=production API_ENV=proton.me webpack --config webpack.config.ts",
        "check-types": "tsc",
        "fmt:native": "cd src-tauri && make fmt",
        "generate:api-types": "yarn workspace @proton/pass generator:openapi \"https://$API/api/internal/doc?page=authenticator\" > ./src/lib/api/types.ts",
        "i18n:extract:desktop": "proton-i18n extract",
        "i18n:getlatest": "proton-i18n upgrade",
        "i18n:upgrade": "proton-i18n extract --verbose && proton-i18n crowdin -u --verbose",
        "i18n:validate": "proton-i18n validate lint-functions",
        "i18n:validate:context:desktop": "proton-i18n validate",
        "lint": "eslint --quiet",
        "lint:native": "cd src-tauri && make lint",
        "make": "tauri bundle -v && bash tools/rename-after-make.sh",
        "start:desktop": "tauri dev --features devtools",
        "start:web": "cross-env API_ENV=proton.black webpack serve --config webpack.config.ts",
        "test": "jest",
        "test:ci": "jest --coverage --runInBand --ci --passWithNoTests"
    },
    "dependencies": {
        "@dnd-kit/collision": "^0.4.0",
        "@dnd-kit/dom": "^0.4.0",
        "@dnd-kit/helpers": "^0.4.0",
        "@dnd-kit/react": "^0.4.0",
        "@proton/atoms": "workspace:^",
        "@proton/colors": "workspace:^",
        "@proton/components": "workspace:^",
        "@proton/icons": "workspace:^",
        "@proton/pass": "workspace:^",
        "@proton/styles": "workspace:^",
        "@proton/types": "workspace:^",
        "@protontech/authenticator-rust-core": "^0.28.8",
        "@protontech/crypto": "*",
        "@reduxjs/toolkit": "^2.11.2",
        "@tanstack/react-virtual": "^3.13.24",
        "@tauri-apps/api": "^2.11.0",
        "@tauri-apps/plugin-dialog": "~2.7.1",
        "@tauri-apps/plugin-fs": "~2.5.1",
        "@tauri-apps/plugin-http": "~2.5.9",
        "@tauri-apps/plugin-log": "~2.8.0",
        "@tauri-apps/plugin-opener": "^2.5.4",
        "@tauri-apps/plugin-process": "~2.3.1",
        "@tauri-apps/plugin-store": "~2.4.3",
        "@tauri-apps/plugin-updater": "~2.10.1",
        "@tauri-apps/plugin-window-state": "~2.4.1",
        "@zxing/browser": "0.2.0",
        "@zxing/library": "0.23.0",
        "browserslist": "^4.28.2",
        "dexie": "^4.4.2",
        "dexie-react-hooks": "^1.1.7",
        "formik": "^2.4.9",
        "jsqr": "^1.4.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-redux": "^9.2.0",
        "ttag": "^1.8.12"
    },
    "devDependencies": {
        "@iarna/toml": "^2.2.5",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
        "@proton/eslint-config-proton": "workspace:^",
        "@proton/i18n": "workspace:^",
        "@proton/pack": "workspace:^",
        "@tauri-apps/cli": "^2.11.2",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "core-js": "^3.49.0",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.4",
        "html-webpack-plugin": "^5.6.7",
        "jest": "^30.4.2",
        "mini-css-extract-plugin": "^2.10.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "webpack": "^5.106.2",
        "webpack-dev-server": "^5.2.5"
    }
}
